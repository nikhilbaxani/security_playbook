# Copia este archivo a .env y rellena SOLO la clave del proveedor que vayas a usar.
# .env está en .gitignore: nunca subas claves al repo.

# Proveedor activo: gemini | claude | openai | ollama
LLM_PROVIDER=gemini

# --- Gemini (por defecto, capa gratuita: https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- Claude (opcional) ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5

# --- OpenAI (opcional) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Ollama (opcional, local, sin clave) ---
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# --- RAG (opcional) ---
# Modelo de embeddings local (multilingüe por defecto: consultas en español
# contra fuentes en inglés). Se descarga de Hugging Face en el primer uso.
# EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
